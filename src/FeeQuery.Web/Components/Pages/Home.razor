@page "/"
@rendermode InteractiveServer
@using FeeQuery.Data
@using FeeQuery.Shared.Models
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject NavigationManager Navigation

<PageTitle>FeeQuery - 系统概览</PageTitle>

<div class="home-page">
    <!-- 页面标题 -->
    <div class="page-header">
        <div>
            <h1 class="page-title">系统概览</h1>
            <p class="page-subtitle">一键掌握多云费用和账号运行状态</p>
        </div>
    </div>

    <!-- 顶部核心指标 -->
    <div class="metrics-row">
        <div class="metric-card primary clickable" @onclick="@(() => Navigation.NavigateTo("/balance-dashboard"))">
            <div class="metric-header">
                <span class="metric-title">总余额</span>
                <Icon Type="wallet" Theme="@IconThemeType.Outline" class="metric-icon" />
            </div>
            <div class="metric-value primary-value">¥ @totalBalance.ToString("N2")</div>
        </div>

        <div class="metric-card clickable" @onclick="@(() => Navigation.NavigateTo("/accounts"))">
            <div class="metric-header">
                <span class="metric-title">账号状态</span>
                <Icon Type="team" Theme="@IconThemeType.Outline" class="metric-icon" />
            </div>
            <div class="metric-stats">
                <div class="stat-item">
                    <span class="stat-value">@totalAccounts</span>
                    <span class="stat-label">总账号</span>
                </div>
                <div class="stat-item">
                    <span class="stat-value success">@normalAccounts</span>
                    <span class="stat-label">正常</span>
                </div>
                <div class="stat-item">
                    <span class="stat-value danger">@errorAccounts</span>
                    <span class="stat-label">异常</span>
                </div>
            </div>
        </div>

        <div class="metric-card clickable" @onclick="@(() => Navigation.NavigateTo("/sync-status"))">
            <div class="metric-header">
                <span class="metric-title">同步状态</span>
                <Icon Type="sync" Theme="@IconThemeType.Outline" class="metric-icon" />
            </div>
            <div class="metric-stats">
                <div class="stat-item">
                    <span class="stat-value">@todaySyncCount</span>
                    <span class="stat-label">今日同步</span>
                </div>
                <div class="stat-item">
                    <span class="stat-value warning">@syncingCount</span>
                    <span class="stat-label">同步中</span>
                </div>
                <div class="stat-item">
                    <span class="stat-value danger">@syncFailedCount</span>
                    <span class="stat-label">失败</span>
                </div>
            </div>
        </div>
    </div>

    <!-- 详细信息区域 -->
    <div class="details-row">
        <!-- 厂商余额状态 -->
        <div class="provider-section">
            <div class="section-header">
                <h2 class="section-title">厂商余额状态</h2>
            </div>
            <div class="provider-grid">
                @if (providerAccounts.Any())
                {
                    @foreach (var item in providerAccounts)
                    {
                        var account = item.Account;
                        var isError = account.LastSyncAt == null ||
                                     (DateTime.UtcNow - account.LastSyncAt.Value).TotalHours > 24;
                        <div class="provider-row @(isError ? "error-row" : "")" @onclick="@(() => NavigateToAccountDetail(account.Id))">
                            <div class="provider-info">
                                <div class="provider-icon">
                                    <Icon Type="cloud" Theme="@IconThemeType.Outline" />
                                </div>
                                <div class="provider-name">
                                    <div class="name-text">@account.Name</div>
                                    <div class="name-id">@MaskAccountId(account.Id)</div>
                                </div>
                            </div>
                            <div class="provider-type">@GetProviderType(account.ProviderCode)</div>
                            <div class="provider-status">
                                @if (isError)
                                {
                                    <span class="status-badge error">查询失败</span>
                                }
                                else
                                {
                                    <span class="status-badge success">正常</span>
                                }
                            </div>
                            <div class="provider-balance">
                                <span class="balance-label">余额:</span>
                                <span class="balance-value @(isError ? "danger" : "success")">
                                    ¥@item.Balance.ToString("N2")
                                </span>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <Empty Description="@("暂无账号数据")" />
                }
            </div>
        </div>

        <!-- 近期预警 -->
        <div class="alert-section">
            <div class="section-header">
                <h2 class="section-title">近期预警</h2>
            </div>
            <div class="alert-list">
                @if (recentAlerts.Any())
                {
                    @foreach (var alert in recentAlerts)
                    {
                        <div class="alert-item @alert.AlertType" @onclick="@(() => NavigateToAlertDetail(alert.Id))">
                            <div class="alert-header">
                                <span class="alert-type-badge">@alert.TypeText</span>
                                <span class="alert-time">@alert.TimeAgo</span>
                            </div>
                            <div class="alert-title">@alert.Title</div>
                            <div class="alert-description">@alert.Description</div>
                        </div>
                    }
                }
                else
                {
                    <Empty Description="@("暂无预警信息")" ImageStyle="height: 60px" />
                }
            </div>
        </div>
    </div>
</div>

<style>
