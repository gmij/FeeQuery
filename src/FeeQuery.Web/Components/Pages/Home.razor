</style>

@code {
    private decimal totalBalance = 0;
    private int totalAccounts = 0;
    private int normalAccounts = 0;
    private int errorAccounts = 0;
    private int todaySyncCount = 0;
    private int syncingCount = 0;
    private int syncFailedCount = 0;

    private List<AccountWithBalance> providerAccounts = new();
    private List<AlertItem> recentAlerts = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadMetrics();
        await LoadProviderAccounts();
        await LoadRecentAlerts();
    }

    private async Task LoadMetrics()
    {
        // 加载账号统计
        totalAccounts = await DbContext.CloudAccounts.CountAsync();

        // 计算24小时前的时间点
        var twentyFourHoursAgo = DateTime.UtcNow.AddHours(-24);
        normalAccounts = await DbContext.CloudAccounts
            .Where(a => a.IsEnabled && a.LastSyncAt.HasValue && a.LastSyncAt.Value >= twentyFourHoursAgo)
            .CountAsync();
        errorAccounts = totalAccounts - normalAccounts;

        // 加载同步统计
        var today = DateTime.UtcNow.Date;
        todaySyncCount = await DbContext.CloudAccounts
            .Where(a => a.LastSyncAt.HasValue && a.LastSyncAt.Value.Date == today)
            .CountAsync();

        // 统计最近1小时内的同步状态（从余额历史记录表查询）
        var oneHourAgo = DateTime.UtcNow.AddHours(-1);

        // 统计同步中的数量
        syncingCount = await DbContext.BalanceHistories
            .Where(h => h.RecordedAt >= oneHourAgo && h.Status == "Running")
            .CountAsync();

        // 统计失败的数量
        syncFailedCount = await DbContext.BalanceHistories
            .Where(h => h.RecordedAt >= oneHourAgo && h.Status == "Failed")
            .CountAsync();

        // 计算总余额：获取每个账号的最新余额记录并求和
        var accountIds = await DbContext.CloudAccounts
            .Where(a => a.IsEnabled)
            .Select(a => a.Id)
            .ToListAsync();

        totalBalance = 0;
        foreach (var accountId in accountIds)
        {
            var latestBalance = await DbContext.BalanceHistories
                .Where(b => b.CloudAccountId == accountId && b.Status == "Success")
                .OrderByDescending(b => b.RecordedAt)
                .Select(b => b.AvailableBalance)
                .FirstOrDefaultAsync();

            totalBalance += latestBalance;
        }
    }

    private async Task LoadProviderAccounts()
    {
        // 获取所有启用的账号
        var accounts = await DbContext.CloudAccounts
            .Where(a => a.IsEnabled)
            .ToListAsync();

        // 为每个账号获取最新的余额记录
        var accountBalances = new List<AccountWithBalance>();

        foreach (var account in accounts)
        {
            // 获取该账号最新的余额记录
            var latestBalance = await DbContext.BalanceHistories
                .Where(b => b.CloudAccountId == account.Id && b.Status == "Success")
                .OrderByDescending(b => b.RecordedAt)
                .FirstOrDefaultAsync();

            accountBalances.Add(new AccountWithBalance
            {
                Account = account,
                Balance = latestBalance?.AvailableBalance ?? 0,
                HasBalance = latestBalance != null
            });
        }

        // 按余额降序排序，然后取前10个
        providerAccounts = accountBalances
            .OrderByDescending(a => a.Balance)
            .Take(10)
            .ToList();
    }

    private async Task LoadRecentAlerts()
    {
        var alertHistories = await DbContext.AlertHistories
            .Include(h => h.CloudAccount)
            .Include(h => h.AlertRule)
            .OrderByDescending(h => h.TriggeredAt)
            .Take(3)
            .ToListAsync();

        recentAlerts = alertHistories.Select(h => new AlertItem
        {
            Id = (int)h.Id,
            AlertType = h.ExceedPercentage > 50 ? "error" : (h.ExceedPercentage > 20 ? "warning" : "info"),
            TypeText = h.ExceedPercentage > 50 ? "余额不足" : (h.ExceedPercentage > 20 ? "余额预警" : "费用提醒"),
            Title = $"{h.CloudAccount?.Name ?? "未知账号"} 余额预警",
            Description = $"当前余额: ¥{h.ActualAmount:N2} / 阈值: ¥{h.ThresholdAmount:N2}",
            TimeAgo = GetTimeAgo(h.TriggeredAt.ToLocalTime())
        }).ToList();

        // 如果没有预警历史，添加示例数据
        if (!recentAlerts.Any())
        {
            recentAlerts = new List<AlertItem>
            {
                new AlertItem
                {
                    AlertType = "error",
                    TypeText = "余额不足",
                    Title = "火山云主账号余额低于阈值",
                    Description = "当前余额: ¥42,560.00 < 阈值 ¥50,000",
                    TimeAgo = "2分钟前"
                },
                new AlertItem
                {
                    AlertType = "warning",
                    TypeText = "同步失败",
                    Title = "腾讯云开发账号同步失败",
                    Description = "凭证已过期，请重新配置",
                    TimeAgo = "15分钟前"
                },
                new AlertItem
                {
                    AlertType = "info",
                    TypeText = "费用提醒",
                    Title = "阿里云本月费用超出预算",
                    Description = "当前: ¥28,750 / 预算: ¥25,000",
                    TimeAgo = "1小时前"
                }
            };
        }
    }

    private string GetProviderType(string providerCode)
    {
        return providerCode.ToLower() switch
        {
            "minimax" => "AI模型",
            _ => "云厂商"
        };
    }

    private string MaskAccountId(int id)
    {
        return $"****{id:D3}";
    }

    private string GetTimeAgo(DateTime time)
    {
        var span = DateTime.Now - time;

        if (span.TotalMinutes < 1)
            return "刚刚";
        if (span.TotalMinutes < 60)
            return $"{(int)span.TotalMinutes}分钟前";
        if (span.TotalHours < 24)
            return $"{(int)span.TotalHours}小时前";
        if (span.TotalDays < 7)
            return $"{(int)span.TotalDays}天前";

        return time.ToString("yyyy-MM-dd");
    }

    private void NavigateToAccountDetail(int accountId)
    {
        // 跳转到账号管理页面
        Navigation.NavigateTo("/accounts");
    }

    private void NavigateToAlertDetail(int alertId)
    {
        // 跳转到预警配置页面
        Navigation.NavigateTo("/balance-alerts");
    }

    private class AlertItem
    {
        public int Id { get; set; }
        public string AlertType { get; set; } = "info";
        public string TypeText { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string TimeAgo { get; set; } = string.Empty;
    }

    private class AccountWithBalance
    {
        public CloudAccount Account { get; set; } = null!;
        public decimal Balance { get; set; }
        public bool HasBalance { get; set; }
    }
}
